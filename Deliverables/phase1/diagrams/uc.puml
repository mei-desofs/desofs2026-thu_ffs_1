@startuml
left to right direction

actor UnregisteredSupplier as "Unregistered Supplier"
actor Admin as "Administrator"
actor Dietitian
actor CentralCanteenManager as "Central Canteen Manager"


rectangle BioCantinas {

    CentralCanteenManager -- (UC1: Authenticate in the system)
    Dietitian -- (UC1: Authenticate in the system)
    Admin -- (UC1: Authenticate in the system)

    CentralCanteenManager -- (UC2: Recover my password)
    Dietitian -- (UC2: Recover my password)
    Admin -- (UC2: Recover my password)

    CentralCanteenManager -- (UC3: Change my password)
    Dietitian -- (UC3: Change my password)
    Admin -- (UC3: Change my password)

    UnregisteredSupplier -- (UC4: Send a Supplier Application)

    Admin -- (UC5: Approve a Supplier Candidate)

    Dietitian -- (UC6: Edit proposed meal planning)
    Dietitian -- (UC7: Publish meal planning)

    CentralCanteenManager -- (UC8: Receive low stock alerts)
    CentralCanteenManager -- (UC9: View dishes reservations history)
    CentralCanteenManager -- (UC10: Order products from suppliers)

}

@enduml